{
  "name": "@bastra-recall/core",
  "version": "0.6.0-beta.1",
  "description": "Reusable core library: vault loader, BM25 index, save_memory. Used by the daemon and the Mac-app.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "check:types": "tsc --noEmit",
    "test": "tsx --test __tests__/*.test.ts",
    "bench:vault-init": "tsx scripts/bench-vault-init.ts"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
