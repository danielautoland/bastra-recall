{
  "name": "@bastra-recall/daemon",
  "version": "0.6.0-beta.1",
  "description": "MCP server exposing recall + load_memory over a markdown vault.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "bastra": "./dist/cli.js",
    "bastra-recall": "./dist/index.js",
    "bastra-recall-mcp": "./dist/mcp-forwarder.js",
    "bastra-recall-bridge": "./dist/bridge.js",
    "bastra-recall-hook": "./dist/hook.js",
    "bastra-recall-session-hook": "./dist/session-hook.js",
    "bastra-recall-prompt-hook": "./dist/prompt-hook.js",
    "bastra-recall-todo-hook": "./dist/todo-hook.js",
    "bastra-recall-bash-pre-hook": "./dist/bash-pre-hook.js",
    "bastra-recall-bash-fail-hook": "./dist/bash-fail-hook.js",
    "bastra-recall-stop-hook": "./dist/stop-hook.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "skill/SKILL.md",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js dist/mcp-forwarder.js dist/bridge.js dist/hook.js dist/session-hook.js dist/prompt-hook.js dist/todo-hook.js dist/bash-pre-hook.js dist/bash-fail-hook.js dist/stop-hook.js dist/cli.js",
    "prepare:package-assets": "node scripts/prepare-package-assets.mjs",
    "prepack": "npm run prepare:package-assets",
    "start": "node dist/index.js",
    "check:types": "tsc --noEmit",
    "test": "tsx --test __tests__/**/*.test.ts",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:telemetry": "tsx scripts/telemetry-smoke.ts",
    "backfill:related": "tsx scripts/backfill-related.ts",
    "eval:robust": "tsx scripts/eval-stress.ts --slice all",
    "test:update": "tsx --test scripts/update-check.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@bastra-recall/core": "0.6.0-beta.1",
    "@bastra-recall/statusline": "0.6.0-beta.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
